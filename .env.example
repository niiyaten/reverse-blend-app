# App URLs
APP_URL=http://127.0.0.1:3000

# Spotify Developer App
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://127.0.0.1:3000/api/auth/callback/spotify

# Supabase browser client
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase server client
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# App security secrets
# Use long random values. Do not reuse your Spotify client secret.
APP_SESSION_SECRET=
APP_TOKEN_ENCRYPTION_SECRET=

# Optional contact link override
# Defaults to /contact when these are empty.
NEXT_PUBLIC_CONTACT_URL=
NEXT_PUBLIC_CONTACT_LABEL=
